{
  "name": "critjecture-workspace",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "start": "pnpm --filter web start",
    "lint": "pnpm --filter web lint",
    "test": "pnpm --filter web test",
    "test:e2e": "pnpm --filter web test:e2e",
    "test:all": "pnpm --filter web test:all",
    "smoke:ui:local": "node ./scripts/playwright-local-ui-smoke.mjs",
    "db:migrate": "pnpm --filter web db:migrate",
    "archive:legacy": "pnpm --filter web archive:legacy",
    "import:v1-foundations": "pnpm --filter web import:v1-foundations",
    "sandbox-supervisor:start": "pnpm --filter sandbox-supervisor start",
    "backup:create": "pnpm --filter web backup:create",
    "backup:restore": "pnpm --filter web backup:restore",
    "backup:verify": "pnpm --filter web backup:verify",
    "restore:drill:hosted": "pnpm --filter web restore:drill:hosted",
    "restore:drill:single-org": "pnpm --filter web restore:drill:single-org",
    "release:proof:hosted": "pnpm --filter web release:proof:hosted",
    "release:proof:single-org": "pnpm --filter web release:proof:single-org"
  },
  "dependencies": {
    "playwright": "^1.59.1"
  }
}
