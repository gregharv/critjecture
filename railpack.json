{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "buildAptPackages": ["curl", "ripgrep"],
  "packages": {
    "node": "20",
    "python": "3.13"
  },
  "steps": {
    "install": {
      "commands": ["..."]
    },
    "build": {
      "commands": [
        "curl -LsSf https://astral.sh/uv/install.sh | sh",
        "cd /app/packages/python-sandbox && /root/.local/bin/uv sync --frozen",
        "..."
      ]
    }
  },
  "deploy": {
    "startCommand": "pnpm start",
    "aptPackages": ["ripgrep"]
  }
}
